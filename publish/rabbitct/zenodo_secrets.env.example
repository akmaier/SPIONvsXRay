# Zenodo credentials for upload_to_zenodo.sh.
# Copy this file to  zenodo_secrets.env  (git-ignored) and fill in your token.
# Create a token at: https://zenodo.org/account/settings/applications/tokens/new
#   scopes: deposit:write, deposit:actions
# For a sandbox dry run (ZENODO_SANDBOX=1), use a token from sandbox.zenodo.org.
#
# NEVER commit a real token. zenodo_secrets.env is git-ignored.

ZENODO_TOKEN=
ZENODO_SANDBOX_TOKEN=
